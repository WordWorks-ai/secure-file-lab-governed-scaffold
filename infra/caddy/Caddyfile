{
  admin off
}

(secure_headers) {
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    -Server
  }
}

(app_routes) {
  @api path /v1/*
  handle @api {
    reverse_proxy api:3000
  }

  handle_path /realtime* {
    reverse_proxy realtime:3010
  }

  handle_path /webhook-sink* {
    reverse_proxy webhook-sink:3020
  }

  handle_path /admin* {
    reverse_proxy admin:80
  }

  handle {
    reverse_proxy web:80
  }
}

:80 {
  encode zstd gzip
  import secure_headers
  import app_routes
}

https://localhost, https://127.0.0.1, https://caddy {
  tls internal
  encode zstd gzip
  import secure_headers
  import app_routes
}
