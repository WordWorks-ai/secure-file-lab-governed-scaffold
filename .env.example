# General
NODE_ENV=development

# API / Worker
API_PORT=3000
WORKER_HEALTH_PORT=3001
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
FILE_UPLOAD_MAX_BYTES=5242880
FILE_UPLOAD_ALLOWED_MIME_TYPES=text/plain,application/pdf,image/png,image/jpeg,application/json
FILE_SCAN_JOB_ATTEMPTS=3
WORKER_SCAN_CONCURRENCY=2
WORKER_EXPIRE_SWEEP_MS=60000
WORKER_CLEANUP_SWEEP_MS=300000
FILE_EXPIRED_RETENTION_SECONDS=86400
WORKER_QUEUE_BOOT_DISABLED=false
POLICY_ENGINE_ENABLED=false
POLICY_ENGINE_FAIL_SAFE_DENY=true
POLICY_ENGINE_TIMEOUT_MS=3000
OPENSEARCH_ENABLED=false
OPENSEARCH_BASE_URL=http://opensearch:9200
OPENSEARCH_FILES_INDEX=files-v1
OPENSEARCH_FAIL_SAFE_DB_FALLBACK=true
SEARCH_INDEX_JOB_ATTEMPTS=3
CONTENT_PIPELINE_ENABLED=false
CONTENT_JOB_ATTEMPTS=3
CONTENT_PREVIEW_MAX_CHARS=500
CONTENT_OCR_MAX_CHARS=2000
PREVIEW_BASE_URL=http://preview:3011
OCR_BASE_URL=http://ocr:3012
DLP_ENGINE_ENABLED=false
DLP_POLICY_ID=dlp-baseline-v1
DLP_MAX_SCAN_BYTES=131072
DLP_ADMIN_OVERRIDE_ENABLED=false
DLP_BASE_URL=http://dlp:3013
METRICS_ENABLED=true

# Postgres
POSTGRES_DB=sfl
POSTGRES_USER=sfl
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sfl:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/sfl?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=secure-files
MINIO_ENDPOINT=http://minio:9000
MINIO_USE_SSL=false

# Vault
VAULT_HOST=vault
VAULT_PORT=8200
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN=CHANGE_ME_VAULT_DEV_TOKEN
VAULT_TRANSIT_KEY_NAME=file-dek-v1

# ClamAV
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# MailHog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025

# Keycloak (optional Stage 10 profile)
KEYCLOAK_SSO_ENABLED=false
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_TIMEOUT_MS=5000
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_HTTP_PORT=8081

# OPA (optional Stage 10 profile)
OPA_BASE_URL=http://opa:8181
OPA_POLICY_PATH=/v1/data/schwass/allow
OPA_HTTP_PORT=8181

# OpenSearch (optional Stage 11 profile)
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_DASHBOARDS_PORT=5601

# Preview + OCR (optional Stage 12 profile)
PREVIEW_PORT=3011
OCR_PORT=3012
PREVIEW_HTTP_PORT=3011
OCR_HTTP_PORT=3012

# DLP (optional Stage 13 profile)
DLP_PORT=3013
DLP_HTTP_PORT=3013

# Observability (optional Stage 14 profile)
PROMETHEUS_HTTP_PORT=9090
LOKI_HTTP_PORT=3100
GRAFANA_HTTP_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# Bootstrap admin seed (Phase 1 scaffold)
BOOTSTRAP_ADMIN_EMAIL=admin@local.test
# generate with: pnpm --filter @sfl/api hash:password -- '<password>'
BOOTSTRAP_ADMIN_PASSWORD_HASH=SET_ARGON2ID_HASH_HERE

# Caddy
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
