# General
NODE_ENV=development

# API / Worker
API_PORT=3000
WORKER_HEALTH_PORT=3001
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Postgres
POSTGRES_DB=sfl
POSTGRES_USER=sfl
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://sfl:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/sfl?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=secure-files
MINIO_ENDPOINT=http://minio:9000
MINIO_USE_SSL=false

# Vault
VAULT_HOST=vault
VAULT_PORT=8200
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN=CHANGE_ME_VAULT_DEV_TOKEN
VAULT_TRANSIT_KEY_NAME=file-dek-v1

# ClamAV
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# MailHog
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
SMTP_HOST=mailhog
SMTP_PORT=1025

# Bootstrap admin seed (Phase 1 scaffold)
BOOTSTRAP_ADMIN_EMAIL=admin@local.test
# generate with: pnpm --filter @sfl/api hash:password -- '<password>'
BOOTSTRAP_ADMIN_PASSWORD_HASH=SET_ARGON2ID_HASH_HERE

# Caddy
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
